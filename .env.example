DATABASE_URL="file:./prisma/dev.db"
ADMIN_PASSWORD="zmen-me"
ADMIN_USERNAME="admin"
PORT=3000

# Volitelné počáteční hodnoty pro prázdnou DB. Existující nastavení z admin UI nepřepisují.
HONEY_TOTAL_JARS=
HONEY_PRICE_PER_JAR_CZK=
HONEY_IBAN=
HONEY_SWIFT=
HONEY_REVOLUT_USERNAME=
HONEY_REVOLUT_LINK=
HONEY_PAYMENT_MESSAGE=

# E-mail notifikace pro admina. Purelymail používá smtp.purelymail.com:465 se SSL/TLS.
SMTP_HOST="smtp.purelymail.com"
SMTP_PORT=465
SMTP_SECURE=true

# Doplň vlastní Purelymail adresu jako login, odesílatele i cílový admin e-mail.
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
ADMIN_EMAIL=

# Ve vývoji může zůstat localhost; v Dockeru/produkci nastav veřejnou URL aplikace.
APP_PUBLIC_URL="http://localhost:3000"

# Vygeneruj náhodný tajný token, např. `openssl rand -hex 32`.
ADMIN_ACTION_SECRET=
ADMIN_CONFIRM_LINK_TTL_HOURS=72
