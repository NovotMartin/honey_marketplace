generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum OrderSource {
  USER
  ADMIN
}

model Settings {
  id              Int      @id @default(1)
  totalJars       Int      @default(100)
  pricePerJarCzk  Int      @default(200)
  iban            String   @default("")
  swift           String   @default("")
  revolutUsername String   @default("")
  revolutLink     String   @default("")
  paymentMessage  String   @default("Platba za med")
  updatedAt       DateTime @updatedAt
}

model Customer {
  id           String   @id @default(cuid())
  name         String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  orders       Order[]
  sessions     CustomerSession[]
  resetTokens  PasswordResetToken[]
}

model CustomerSession {
  id         String    @id @default(cuid())
  customerId String
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime  @default(now())
  revokedAt  DateTime?
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([revokedAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  customerId String
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  usedAt     DateTime?
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([expiresAt])
  @@index([usedAt])
}

model Order {
  id          String      @id @default(cuid())
  customerId  String
  jarCount    Int
  status      OrderStatus @default(PENDING)
  source      OrderSource @default(USER)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  cancelledAt DateTime?
  customer    Customer    @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
}
